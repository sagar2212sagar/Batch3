{
  "datasets": [
    {
      "name": "kpi_total_resumes",
      "displayName": "Total Resumes",
      "queryLines": [
        "SELECT COUNT(*) AS total_resumes FROM resume_company_data_final"
      ],
      "catalog": "resume_batch3",
      "schema": "gold"
    },
    {
      "name": "kpi_selected",
      "displayName": "Selected Candidates",
      "queryLines": [
        "SELECT COUNT(*) AS selected_candidates FROM resume_company_data_final WHERE match = 'Selected'"
      ],
      "catalog": "resume_batch3",
      "schema": "gold"
    },
    {
      "name": "kpi_match_rate",
      "displayName": "Match Rate",
      "queryLines": [
        "SELECT ROUND(SUM(CASE WHEN match='Selected' THEN 1 ELSE 0 END) / COUNT(*), 2) AS match_rate FROM resume_company_data_final"
      ],
      "catalog": "resume_batch3",
      "schema": "gold"
    },
    {
      "name": "kpi_jobs",
      "displayName": "Total Jobs",
      "queryLines": [
        "SELECT COUNT(DISTINCT company_jd_id) AS total_jobs FROM resume_company_data_final"
      ],
      "catalog": "resume_batch3",
      "schema": "gold"
    },
    {
      "name": "match_rate_by_job",
      "displayName": "Match Rate by Job",
      "queryLines": [
        "SELECT jd.title,COUNT(*) AS total_resumes,SUM(CASE WHEN g.match = 'Selected' THEN 1 ELSE 0 END) AS matched_resumes,ROUND(SUM(CASE WHEN g.match = 'Selected' THEN 1 ELSE 0 END) / COUNT(*), 2) AS match_rate_pct FROM resume_company_data_final g JOIN company_jd jd ON g.company_jd_id = jd.company_jd_id GROUP BY jd.title ORDER BY match_rate_pct DESC"
      ],
      "catalog": "resume_batch3",
      "schema": "gold"
    },
    {
      "name": "experience_distribution",
      "displayName": "Experience Distribution",
      "queryLines": [
        "SELECT r.experience,COUNT(*) AS qualified_candidates FROM resume_company_data_final g JOIN resume_data r ON g.resume_id = r.resume_id WHERE g.match = 'Selected'GROUP BY r.experience ORDER BY qualified_candidates DESC"
      ],
      "catalog": "resume_batch3",
      "schema": "gold"
    },
    {
      "name": "country_distribution",
      "displayName": "Country Distribution",
      "queryLines": [
        "SELECT r.country,COUNT(*) AS candidate_count FROM resume_company_data_final g JOIN resume_data r ON g.resume_id = r.resume_id GROUP BY r.country ORDER BY candidate_count DESC LIMIT 10"
      ],
      "catalog": "resume_batch3",
      "schema": "gold"
    },
    {
      "name": "skills_summary",
      "displayName": "Top Skills",
      "queryLines": [
        "SELECT skill,COUNT(*) AS matched_count FROM (SELECT explode(split(jd.skills, ',')) AS skill FROM resume_company_data_final g JOIN company_jd jd ON g.company_jd_id = jd.company_jd_id WHERE g.match = 'Selected')GROUP BY skill ORDER BY matched_count DESC LIMIT 10"
      ],
      "catalog": "resume_batch3",
      "schema": "gold"
    },
    {
      "name": "rejection_reasons",
      "displayName": "Rejection Reasons",
      "queryLines": [
        "SELECT reason,COUNT(*) AS frequency,ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 2) AS percentage FROM resume_company_data_final WHERE match = 'Rejected' GROUP BY reason ORDER BY frequency DESC LIMIT 10"
      ],
      "catalog": "resume_batch3",
      "schema": "gold"
    }
  ],
